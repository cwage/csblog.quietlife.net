FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir beautifulsoup4 html2text requests

ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY scripts/scrape.py /app/scrape.py
COPY scripts/rewrite_links.py /app/rewrite_links.py

ENTRYPOINT ["python", "/app/scrape.py"]
